{
  "name": "chw-api",
  "version": "1.0.0",
  "description": "chw-api",
  "main": "build/index.js",
  "scripts": {
    "check": "pnpm exec @biomejs/biome check --apply ./src",
    "dev": "pnpm run spec:routes && concurrently \"nodemon\" \"nodemon -x tsoa spec-and-routes\"",
    "generate": "pnpm exec prisma generate",
    "build": "pnpm run generate && tsoa spec-and-routes && tsc",
    "start": "node src/index.js",
    "spec:routes": "pnpm exec tsoa spec-and-routes",
    "migrate": "pnpm exec prisma migrate dev",
    "migrate:deploy": "pnpm exec prisma migrate deploy",
    "seed": "ts-node ./prisma/seeds/index.ts",
    "seed:recommendations-test": "psql \"$DATABASE_URL\" -f ./scripts/seed-local-recommendations-test.sql",
    "backfill:section-numbers": "ts-node ./scripts/backfill-section-numbers.ts",
    "update:user-language-rw": "bash ./scripts/update-user-language-rw.sh",
    "update:cho-to-ceho": "ts-node ./scripts/update-cho-to-ceho.ts",
    "reset": "pnpm exec prisma migrate reset",
    "lint": "pnpm exec eslint ./src --fix",
    "format": "prettier --write ./src",
    "prepare": "husky install",
    "lint-staged": "lint-staged",
    "build:dev": "tsc --outDir dist-dev",
    "test:cache": "ts-node ./src/utils/cacheTestSuite.ts"
  },
  "engines": {
    "node": ">=20.19.0",
    "pnpm": ">=8.0.0"
  },
  "packageManager": "pnpm@8.15.4",
  "keywords": [],
  "author": "",
  "license": "ISC",
  "devDependencies": {
    "@biomejs/biome": "1.7.3",
    "@commitlint/cli": "^19.3.0",
    "@eslint/js": "^9.4.0",
    "@types/bcrypt": "^5.0.2",
    "@types/cors": "^2.8.17",
    "@types/express": "^4.17.21",
    "@types/http-proxy-middleware": "^1.0.0",
    "@types/jsonwebtoken": "^9.0.6",
    "@types/node": "^25.5.0",
    "@types/node-schedule": "^2.1.7",
    "@types/nodemailer": "^6.4.16",
    "@types/sharp": "^0.32.0",
    "@types/swagger-ui-express": "^4.1.6",
    "@types/uuid": "^9.0.8",
    "@typescript-eslint/eslint-plugin": "^7.13.0",
    "@typescript-eslint/parser": "^7.13.0",
    "concurrently": "^8.2.2",
    "eslint": "^8.56.0",
    "eslint-config-prettier": "^9.1.0",
    "eslint-plugin-prettier": "^5.1.3",
    "globals": "^15.4.0",
    "husky": "^8.0.0",
    "lint-staged": "^15.2.6",
    "nodemon": "^3.1.0",
    "prettier": "^3.3.2",
    "rimraf": "^5.0.7",
    "ts-node": "^10.9.2",
    "tsoa": "^6.2.1",
    "typescript": "^5.4.5",
    "typescript-eslint": "^7.13.0"
  },
  "dependencies": {
    "@dev-heir/express-logs": "^1.0.2",
    "@prisma/client": "^5.15.0",
    "@tsoa/runtime": "^6.2.1",
    "@types/multer": "^1.4.11",
    "@types/pg": "^8.20.0",
    "@types/qrcode": "^1.5.6",
    "@types/xlsx": "^0.0.36",
    "axios": "^1.7.2",
    "bcrypt": "^5.1.1",
    "cloudinary": "^2.7.0",
    "cors": "^2.8.5",
    "dayjs": "^1.11.12",
    "dotenv": "^16.4.5",
    "exceljs": "^4.4.0",
    "express": "^4.19.2",
    "firebase-admin": "^13.7.0",
    "http-proxy-middleware": "^3.0.5",
    "ioredis": "^5.10.1",
    "jsonwebtoken": "^9.0.2",
    "multer": "^1.4.3",
    "multer-storage-cloudinary": "^4.0.0",
    "node-cron": "^4.1.0",
    "node-schedule": "^2.1.1",
    "nodemailer": "^6.9.15",
    "paypack-js": "^0.2.1",
    "pdf-lib": "^1.17.1",
    "pdf-parse": "^1.1.1",
    "pg": "^8.20.0",
    "prisma": "^5.14.0",
    "qrcode": "^1.5.4",
    "read-excel-file": "^5.8.2",
    "reflect-metadata": "^0.1.13",
    "sharp": "^0.35.1",
    "socket.io": "^4.8.1",
    "swagger-ui-express": "^5.0.0",
    "twilio": "^5.9.0",
    "uuid": "^9.0.1",
    "xlsx": "^0.18.5",
    "zod": "^3.23.8"
  },
  "lint-staged": {
    "*.{js,jsx,ts,tsx}": [
      "eslint ./src --fix",
      "prettier --write .",
      "git add ."
    ]
  }
}
