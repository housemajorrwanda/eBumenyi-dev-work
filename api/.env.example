# Database Configuration
DATABASE_URL="postgresql://username:password@host:port/database"

# Server Configuration
PORT=9000

# JWT Configuration
JWT_SECRET='your-jwt-secret-key'
JWT_EXPIRES_IN='5h'
SALT_ROUNDS=5

# Application Configuration
APP_NAME="UMUJYANAMA"

# Cookie Configuration (for cross-subdomain authentication)
# Set this to enable cookies across subdomains (e.g., .ebumenyi.online for *.ebumenyi.online)
# Leave empty for single domain
COOKIE_DOMAIN=".ebumenyi.online"

# Cloudinary Configuration (for file uploads)
CLOUD_NAME="your-cloudinary-cloud-name"
CLOUDINARY_API_KEY="your-cloudinary-api-key"
CLOUDINARY_API_SECRET="your-cloudinary-api-secret"

# Email Configuration (Gmail SMTP)
EMAIL_USER="your-email@gmail.com"
EMAIL_PASS="your-app-password"

# Twilio Configuration (SMS/Phone verification)
TWILIO_ACCOUNT_SID="your-twilio-account-sid"
TWILIO_AUTH_TOKEN="your-twilio-auth-token"
TWILIO_VERIFY_SERVICE_SID="your-twilio-verify-service-sid"
TWILIO_MESSAGING_SERVICE_SID="your-twilio-messaging-service-sid"
SMS_TIMEOUT_MS="10000"
```
LLM_BASE_URL="http://localhost:11434/v1"
# Not required for self-hosted Ollama; leave empty unless your LLM gateway needs it.
LLM_API_KEY=
LLM_MODEL="llama3.2"
# Max time (ms) to wait for an LLM response before giving up (default 20000).
# Self-hosted CPU inference can be slow — consider 60000–120000 on Railway.
LLM_TIMEOUT_MS=

# ML Service (OCR + Kinyarwanda TTS) — self-hosted ml-service
ML_SERVICE_URL="http://localhost:8100"